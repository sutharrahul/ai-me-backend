# Copy this file to .env and fill in your values.

APP_NAME="RAG Backend"
ENVIRONMENT=development

# Comma-separated list is not supported directly; edit CORS_ORIGINS in app/config.py
# if you need multiple origins, or set as a JSON array via env: ["http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# Provider selection: "gemini" (default), "openai", or "ollama"
EMBEDDING_PROVIDER=gemini
LLM_PROVIDER=gemini

# Google Gemini (get a key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash
EMBEDDING_DIMENSIONS=768

# OpenAI (optional fallback - only used if EMBEDDING_PROVIDER/LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Ollama (local/free - only used if EMBEDDING_PROVIDER/LLM_PROVIDER=ollama)
# Run `ollama serve` and pull the models first:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector store selection: "postgres" (default, pgvector) or "qdrant"
VECTOR_STORE_PROVIDER=postgres

# Postgres / pgvector - matches docker-compose.yml defaults.
# Run `docker compose up -d postgres` to start it locally.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# Qdrant (alternative vector store - only used if VECTOR_STORE_PROVIDER=qdrant)
# Run `docker compose up -d qdrant` to start it locally.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
DEFAULT_TOP_K=4

# Rate limiting - max questions a single IP can ask per day (no auth
# required). Protects the paid embedding/LLM APIs from being drained by
# one visitor or a bot.
DAILY_QUESTION_LIMIT=20

# Query caching (Redis) - repeat questions are served from cache instead
# of re-running the embedding + LLM calls. Run `docker compose up -d redis`
# to start it locally. Purely an optimization: if Redis is unreachable,
# caching silently disables itself.
ENABLE_QUERY_CACHE=true
REDIS_URL=redis://localhost:6379/0
QUERY_CACHE_TTL_SECONDS=3600
